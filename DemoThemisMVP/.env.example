# Copy to .env (repo root) for Foundry scripts. NEVER commit .env.
# The deployer key is project-only, demo scale; never a personal key.

PRIVATE_KEY=
DEPLOYER_ADDRESS=

# Supported World ID Router path. Leave WORLD_ID_ROUTER empty for the disclosed
# Sepolia mock cohort; set it to the documented mainnet address for production.
# The preview World ID 4.0 verifier is deliberately not a Deploy.s.sol option.
WORLD_ID_ROUTER=
WORLD_ID_ROUTER_MAINNET=0x17B354dD2595411ff79041f930e491A4Df39A278
WORLD_ID_APP_ID=app_7bdfda4db4e2f59dd4a2427cd2bd860d

# Developer Portal app ids (staging app for Sepolia tooling, unlisted production app for mainnet)
WORLD_APP_ID_STAGING=
WORLD_APP_ID_PROD=

# RPC
RPC_WORLDCHAIN_SEPOLIA=https://worldchain-sepolia.g.alchemy.com/public
RPC_WORLDCHAIN_MAINNET=https://worldchain-mainnet.g.alchemy.com/public
