# Copy to .env (repo root) for Foundry scripts. NEVER commit .env.
# The deployer key is project-only, demo scale; never a personal key.

PRIVATE_KEY=
DEPLOYER_ADDRESS=

# World ID 4.0 Production path. Leave WORLD_ID_VERIFIER empty only for the
# disclosed Sepolia mock cohort. World Chain mainnet accepts exactly this proxy.
WORLD_ID_VERIFIER=
WORLD_ID_VERIFIER_MAINNET=0x00000000009E00F9FE82CfeeBB4556686da094d7
WORLD_ID_RP_ID=0x1ddcf8ba2efe3f36

# Developer Portal app ids (staging app for Sepolia tooling, unlisted production app for mainnet)
WORLD_APP_ID_STAGING=
WORLD_APP_ID_PROD=

# RPC
RPC_WORLDCHAIN_SEPOLIA=https://worldchain-sepolia.g.alchemy.com/public
RPC_WORLDCHAIN_MAINNET=https://worldchain-mainnet.g.alchemy.com/public
