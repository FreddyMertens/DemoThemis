# Copy to .env (repo root) for Foundry scripts. NEVER commit .env.
# The deployer key is project-only, demo scale; never a personal key.

PRIVATE_KEY=
DEPLOYER_ADDRESS=

# World ID routers (verify against docs.world.org/world-id/idkit/onchain-verification)
WORLD_ID_ROUTER=0x57f928158C3EE7CDad1e4D8642503c4D0201f611
WORLD_ID_ROUTER_MAINNET=0x17B354dD2595411ff79041f930e491A4Df39A278

# World ID 4.0 on-chain verifier (WC MAINNET only) for the WorldIDGate deploy path.
# Set this to switch Deploy.s.sol from the cohort MockSybilGate to the real gate.
# Staging  (Step 3.5, simulator proofs): 0x703a6316c975DEabF30b637c155edD53e24657DB
# Production (Step 5, Orb/Device humans): 0x00000000009E00F9FE82CfeeBB4556686da094d7
WORLD_ID_VERIFIER=

# Developer Portal app ids (staging app for Sepolia tooling, unlisted production app for mainnet)
WORLD_APP_ID_STAGING=
WORLD_APP_ID_PROD=

# RPC
RPC_WORLDCHAIN_SEPOLIA=https://worldchain-sepolia.g.alchemy.com/public
RPC_WORLDCHAIN_MAINNET=https://worldchain-mainnet.g.alchemy.com/public
